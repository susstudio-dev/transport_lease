# =============================================================================
# Frontend (prefixed with VITE_, exposed to the browser)
# =============================================================================

# Supabase project — get from https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Razorpay — get from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys until go-live, then swap to rzp_live_*
VITE_RAZORPAY_KEY_ID=

# App environment: development | staging | production
VITE_APP_ENV=development

# =============================================================================
# Edge Function secrets (NEVER expose to frontend — no VITE_ prefix)
# Set via: supabase secrets set KEY=value
# =============================================================================

# Supabase service role key (admin operations, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — secret + webhook signing secret
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Resend (transactional email) — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# MSG91 (transactional SMS) — https://control.msg91.com
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
